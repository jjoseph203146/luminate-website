# Copy this file to .env.local and fill in the values from your Supabase project.
# Use the same Supabase project as Luminate OS — anon/public key only, never the service role key.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The Luminate OS backend base URL
NEXT_PUBLIC_LUMINATE_OS_URL=https://luminate-os.vercel.app
